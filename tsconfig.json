{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": [
    "src/store/infraStore.ts",
    "src/store/infraStoreV2.ts",
    "src/store/infraStoreV3.ts",
    "src/components/ServerInventoryPanel.tsx",
    "src/components/NodeDetailDialog.tsx",
    "src/components/NodeDetailDialogV2.tsx",
    "src/components/NodeEditDialog.tsx"
  ]
}
